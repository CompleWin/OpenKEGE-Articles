---
import { getCollection } from 'astro:content';
import FormattedDate from './FormattedDate.astro';
import { CATEGORIES, type Category } from '../consts'

const posts = await getCollection('articles');

const grouped = posts.reduce((acc, post) => {
  const cat = post.data.category;
  (acc[cat] ||= []).push(post);
  return acc;
}, {} as Record<Category, typeof posts>);

for (const cat in grouped) {
  grouped[cat as Category].sort(
    (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
}

const categories = CATEGORIES.filter(cat => grouped[cat]?.length);
---

<section>
  <h1 class="text-4xl font-bold text-ink mb-8">Все статьи</h1>

  {categories.map(category => (
    <div class="mb-10">
      <h2 class="text-2xl font-bold text-ink mb-3">{category}</h2>
      <ul>
        {grouped[category].map(post => (
          <li class="flex items-baseline justify-between gap-4 py-2 border-b border-soft">
            <a
              href={`/article/${post.id}/`}
              class="text-ink no-underline hover:text-accent transition-colors"
            >
              {post.data.title}
            </a>
            <span class="text-sm text-muted shrink-0">
              <FormattedDate date={post.data.pubDate} />
            </span>
          </li>
        ))}
      </ul>
    </div>
  ))}
</section>
